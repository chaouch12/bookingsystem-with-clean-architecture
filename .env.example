# Docker / infrastructure
COMPOSE_PROJECT_NAME=booking-system
APP_PORT=18080
APP_DOMAIN=bookingsystem-dev.de
MYSQL_PORT=13306
MYSQL_DATABASE=booking_system
MYSQL_USER=booking
MYSQL_PASSWORD=booking
MYSQL_ROOT_PASSWORD=root
REDIS_PORT=6379
MAILPIT_UI_PORT=18025
MAILPIT_SMTP_PORT=11026

# Symfony (backend/.env.local will mirror DATABASE_URL)
DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}?serverVersion=8.4&charset=utf8mb4"
