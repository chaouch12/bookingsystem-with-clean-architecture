#!/bin/sh

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND_DIR="$REPO_ROOT/backend"

if [ -x /opt/homebrew/bin/php ]; then
    PHP_BIN="/opt/homebrew/bin/php"
else
    PHP_BIN="$(command -v php)"
fi
GIT_USER="$(git config user.name)"
GIT_EMAIL="$(git config user.email)"
COMMIT_MSG_FILE="$1"

case "$COMMIT_MSG_FILE" in
    /*) ;;
    *) COMMIT_MSG_FILE="$REPO_ROOT/$COMMIT_MSG_FILE" ;;
esac

DIFF="$(git -c diff.mnemonicprefix=false -c diff.noprefix=false --no-pager diff --raw -r -p -m -M --full-index --no-color --staged | cat)"

export GRUMPHP_GIT_WORKING_DIR="$REPO_ROOT"

cd "$BACKEND_DIR"
printf "%s\n" "$DIFF" | "$PHP_BIN" vendor/bin/grumphp git:commit-msg "--git-user=$GIT_USER" "--git-email=$GIT_EMAIL" "$COMMIT_MSG_FILE"
